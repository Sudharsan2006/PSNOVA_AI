# ── Server ──────────────────────────────────
PORT=5000
NODE_ENV=development

# ── MongoDB Atlas ────────────────────────────
# Get from: https://cloud.mongodb.com -> Connect -> Drivers
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/teamai?retryWrites=true&w=majority

# ── OpenAI (optional — for AI chatbot) ───────
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ── Client URL (CORS) ────────────────────────
CLIENT_URL=http://localhost:5173

# ── Email (optional — for contact notifications) ──
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password
